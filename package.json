{
  "name": "jizy-storage",
  "version": "2.1.5",
  "browser": "dist/js/jizy-storage.min.js",
  "main": "lib/index.js",
  "type": "module",
  "author": "Joffrey Demetz <joffrey.demetz@gmail.com> (https://joffreydemetz.com/)",
  "license": "MIT",
  "description": "A simple JS storage proxy.",
  "homepage": "https://jizy.joffreydemetz.com/storage",
  "keywords": [
    "jizy",
    "storage",
    "proxy"
  ],
  "files": [
    "dist/*",
    "lib/*"
  ],
  "scripts": {
    "jpack:dist": "node ./cli/jpack.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/tests/*.test.js"
    ],
    "transform": {}
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joffreydemetz/jizy-storage.git"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jizy-packer": "^2.1.44"
  }
}